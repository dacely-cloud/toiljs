# Per-tenant PLAIN vars. Copy to `.env` (gitignored) for `toiljs dev`.
# Read from server code with `Environment.get("KEY")` (returns the value or null).
# Loaded out of band by the edge -- NEVER bundled into the .wasm.
#
# Demoed by GET /env/show (server/routes/EnvDemo.ts).

PUBLIC_GREETING=hello from the env
REGION=eu
