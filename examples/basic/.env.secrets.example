# Per-tenant SECRETS. Copy to `.env.secrets` (gitignored, keep mode 0600) for
# `toiljs dev`. Read from server code with `Environment.getSecure("KEY")`.
# A secret is NEVER returned by Environment.get() -- the buckets are disjoint.

DEMO_API_KEY=sk_demo_replace_me

# Reserved TOIL_* keys are HOST-ONLY: the edge reads them (e.g. the mailer), but
# they are unreachable from Environment.get()/getSecure(). Uncomment to enable
# email for this tenant (see docs/email.md):
# TOIL_EMAIL_ENABLED=true
# TOIL_EMAIL_PROVIDER=resend
# TOIL_EMAIL_FROM=you@example.com
# TOIL_EMAIL_API_KEY=re_xxxxxxxxxxxx
