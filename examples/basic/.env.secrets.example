# Per-tenant SECRETS. Copy to `.env.secrets` (gitignored, keep mode 0600) for
# `toiljs dev`. Read from server code with `Environment.getSecure("KEY")`.
# A secret is NEVER returned by Environment.get() -- the buckets are disjoint.

DEMO_API_KEY=sk_demo_replace_me

# Toil PQ-Auth secrets (server/routes/Auth.ts). Each is read with
# Environment.getSecure(); LEFT UNSET they fall back to built-in DEV defaults so
# the demo runs out of the box. Set them for any non-throwaway use.
# AUTH_SESSION_SECRET=change-me-to-a-long-random-secret
# AUTH_OPRF_SEED=change-me-to-a-random-value
# Server ML-KEM-768 secret key (hex). Must match the public key pinned in the
# client (src/client/auth.ts). Unset uses the demo keypair; for a real one,
# generate a fresh pair and pin its public key in the client.
# AUTH_KEM_SK=<2400-byte hex>

# Cookies/crypto demo key (server/core/AppHandler.ts). Unset -> DEV default.
# DEMO_COOKIE_KEY=any-secret-string

# Reserved TOIL_* keys are HOST-ONLY: the edge reads them (e.g. the mailer), but
# they are unreachable from Environment.get()/getSecure(). Uncomment to enable
# email for this tenant (see docs/email.md):
# TOIL_EMAIL_ENABLED=true
# TOIL_EMAIL_PROVIDER=resend
# TOIL_EMAIL_FROM=you@example.com
# TOIL_EMAIL_API_KEY=re_xxxxxxxxxxxx
