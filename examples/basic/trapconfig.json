{
    "entries": ["server/trap-main.ts"],
    "targets": {
        "release": {
            "outFile": "build/server/trap.wasm",
            "textFile": "build/server/trap.wat"
        }
    },
    "options": {
        "sourceMap": false,
        "optimizeLevel": 3,
        "shrinkLevel": 1,
        "converge": true,
        "noAssert": false,
        "enable": [
            "sign-extension",
            "mutable-globals",
            "nontrapping-f2i",
            "bulk-memory",
            "simd",
            "reference-types",
            "multi-value"
        ],
        "runtime": "stub",
        "memoryBase": 65536,
        "initialMemory": 4,
        "debug": false,
        "trapMode": "allow"
    }
}
