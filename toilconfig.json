{
    "entries": ["src/backend/index.ts"],
    "targets": {
        "release": {
            "outFile": "build/backend/release.wasm",
            "textFile": "build/backend/release.wat"
        }
    },
    "options": {
        "sourceMap": false,
        "optimizeLevel": 3,
        "shrinkLevel": 1,
        "converge": true,
        "noAssert": false,
        "enable": [
            "sign-extension",
            "mutable-globals",
            "nontrapping-f2i",
            "bulk-memory",
            "simd",
            "reference-types",
            "multi-value"
        ],
        "runtime": "stub",
        "memoryBase": 0,
        "initialMemory": 1,
        "debug": false,
        "trapMode": "allow"
    }
}
