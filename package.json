{
    "name": "toiljs",
    "type": "module",
    "version": "0.0.1",
    "author": "OP_NET",
    "description": "todo",
    "engines": {
        "node": ">=24.0.0"
    },
    "exports": {
        ".": {
            "types": "./build/client/index.d.ts",
            "import": "./build/client/index.js",
            "default": "./build/client/index.js"
        },
        "./client": {
            "types": "./build/client/index.d.ts",
            "import": "./build/client/index.js",
            "default": "./build/client/index.js"
        },
        "./compiler": {
            "types": "./build/compiler/index.d.ts",
            "import": "./build/compiler/index.js",
            "default": "./build/compiler/index.js"
        },
        "./logger": {
            "types": "./build/logger/index.d.ts",
            "import": "./build/logger/index.js",
            "default": "./build/logger/index.js"
        },
        "./shared": {
            "types": "./build/shared/index.d.ts",
            "import": "./build/shared/index.js",
            "default": "./build/shared/index.js"
        }
    },
    "bin": {
        "toil": "./build/cli/index.js"
    },
    "homepage": "https://opnet.org",
    "keywords": [
        "opnet",
        "bitcoin",
        "btc"
    ],
    "license": "Apache-2.0",
    "main": "build/client/index.js",
    "types": "build/client/index.d.ts",
    "typings": "build/client/index.d.ts",
    "module": "build/client/index.js",
    "publishConfig": {
        "access": "public",
        "tag": "latest"
    },
    "scripts": {
        "watch": "tsc -p tsconfig.json --watch",
        "build": "npm run build:shared && npm run build:logger && npm run build:client && npm run build:compiler && npm run build:cli && npm run build:backend",
        "build:shared": "tsc -p tsconfig.shared.json",
        "build:logger": "tsc -p tsconfig.logger.json",
        "build:client": "tsc -p tsconfig.client.json",
        "build:compiler": "tsc -p tsconfig.compiler.json",
        "build:cli": "tsc -p tsconfig.cli.json",
        "build:backend": "toilscript --target release",
        "test": "vitest run --coverage",
        "test:watch": "vitest",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest run --coverage",
        "test:backend": "asp --config as-pect.config.js --verbose --no-logo",
        "test:backend:ci": "asp --config as-pect.config.js --summary --no-logo",
        "test:all": "npm run test && npm run test:backend",
        "lint": "eslint src",
        "docs": "typedoc --out docs --tsconfig tsconfig.json --readme README.md --name TOILJS --plugin typedoc-material-theme --themeColor '#cb9820' --exclude src/backend src",
        "setup": "npm i && npm run build"
    },
    "dependencies": {
        "@btc-vision/as-bignum": "^1.0.0",
        "@btc-vision/as-loader": "^0.0.0",
        "toilscript": "^0.1.1",
        "@vitejs/plugin-react": "^6.0.2",
        "vite": "^8.0.14"
    },
    "peerDependencies": {
        "react": ">=18.0.0",
        "react-dom": ">=18.0.0"
    },
    "devDependencies": {
        "@babel/core": "^7.29.7",
        "@babel/preset-env": "^7.29.7",
        "@babel/preset-typescript": "^7.29.7",
        "@btc-vision/as-covers-assembly": "^0.4.5",
        "@btc-vision/as-covers-transform": "^0.4.5",
        "@btc-vision/as-pect-assembly": "^8.3.0",
        "@btc-vision/as-pect-cli": "^8.3.0",
        "@btc-vision/as-pect-transform": "^8.3.0",
        "@eslint/js": "^10.0.1",
        "@microsoft/api-extractor": "7.58.7",
        "@types/node": "^25.9.1",
        "@types/react": "^19.2.15",
        "@types/react-dom": "^19.2.3",
        "@vitest/coverage-v8": "^4.1.7",
        "@vitest/ui": "^4.1.7",
        "micromatch": "^4.0.8",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "typedoc": "^0.28.19",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.0",
        "vitest": "^4.1.7"
    }
}
