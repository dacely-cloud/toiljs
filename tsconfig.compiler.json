{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "module": "ESNext",
        "target": "ESNext",
        "moduleResolution": "bundler",
        "rootDir": "src/compiler",
        "outDir": "build/compiler",
        "types": ["node"],
        "tsBuildInfoFile": "build/compiler/.tsbuildinfo"
    },
    "include": ["src/compiler/**/*"]
}
